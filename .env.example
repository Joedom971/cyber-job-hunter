# ──────────────────────────────────────────────────────────
# Cyber Job Hunter — variables d'environnement (template)
# Copie ce fichier en `.env` puis remplis les valeurs.
# Le `.env` est ignoré par git — ne JAMAIS le committer.
# ──────────────────────────────────────────────────────────

# ─── Email digest (Sprint 3) ─────────────────────────────
# Compte Gmail dédié au scraper (NE PAS utiliser ton perso)
# Crée un compte spécifique + active 2FA + génère un App Password 16 chars.
# Doc: https://myaccount.google.com/apppasswords
GMAIL_USER=tonprenom.cyberjobhunter@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Destinataire du digest (où tu lis tes mails)
DIGEST_RECIPIENT=tonemail@proton.me

# Paramètres du digest
DIGEST_MIN_SCORE=60
DIGEST_MAX_JOBS=10
DIGEST_DASHBOARD_URL=http://localhost:8501

# ─── Scraping ────────────────────────────────────────────
# User-Agent honnête (politesse + traçabilité)
SCRAPER_USER_AGENT=JobHunterBot/1.0 (+contact: ton@email.tld)

# Rate limit par défaut (secondes entre 2 requêtes même domaine)
SCRAPER_RATE_LIMIT_SECONDS=3

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
